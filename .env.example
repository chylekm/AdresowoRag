# OpenRouter (wymagane dla POST /rag/answer)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Embedding model (lokalny, sentence-transformers)
EMBED_MODEL=intfloat/multilingual-e5-small

# Ścieżki danych i indeksu
DATA_PATH=data/ogloszenia_warszawa_detailed.csv
INDEX_DIR=index

# Parametry wyszukiwania
DEFAULT_TOP_K=5
MAX_TOP_K=20
CHUNK_SIZE=1000
CHUNK_OVERLAP=100

# Aplikacja
APP_ENV=development
APP_VERSION=1.0.0
